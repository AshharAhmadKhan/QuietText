{
  "manifest_version": 3,
  "name": "QuietText",
  "version": "1.0",
  "description": "Dyslexia-friendly AI reading assistant for any webpage.",
  "permissions": ["storage", "contextMenus", "activeTab", "scripting"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*", "https://api.groq.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "fonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
